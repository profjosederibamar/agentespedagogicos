# ═══════════════════════════════════════════════════════════════
# CONFIGURAÇÃO DE API KEYS — Plataforma de Agentes Pedagógicos
# ═══════════════════════════════════════════════════════════════
# Copie este arquivo como .env e preencha com suas chaves.

# HuggingFace (https://huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=hf_SEU_TOKEN_AQUI

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=SUA_CHAVE_GEMINI_AQUI

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=SUA_CHAVE_GROQ_AQUI

# Modelo padrão do HuggingFace
AI_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# Ambiente
ENVIRONMENT=development

